# Simple cube
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5

vn  0  0  1
vn  0  0 -1
vn  1  0  0
vn -1  0  0
vn  0  1  0
vn  0 -1  0

# Front
f 1//1 2//1 3//1 4//1
# Back
f 6//2 5//2 8//2 7//2
# Right
f 2//3 6//3 7//3 3//3
# Left
f 5//4 1//4 4//4 8//4
# Top
f 4//5 3//5 7//5 8//5
# Bottom
f 5//6 6//6 2//6 1//6
